{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# RecSys 2026 — BM25 Baseline\n",
    "\n",
    "Run the BM25 retrieval baseline end-to-end:\n",
    "1. Build BM25 index over track catalog\n",
    "2. Retrieve top-20 tracks per dialogue turn\n",
    "3. Evaluate with nDCG@{1,10,20}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.insert(0, '..')\n",
    "\n",
    "from pathlib import Path\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv('../.env')\n",
    "\n",
    "from src.utils.data_loader import load_split, load_track_metadata\n",
    "from src.retrieval.bm25_retrieval import BM25Retriever\n",
    "from src.evaluation.metrics import compute_ndcg, compute_catalog_coverage\n",
    "\n",
    "DATA_DIR = Path('../data/raw')\n",
    "TOP_K = 20\n",
    "print('Imports done ✅')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "tracks_df = load_track_metadata(data_dir=DATA_DIR)\n",
    "dev_ds = load_split('dev', data_dir=DATA_DIR)\n",
    "dev_df = dev_ds.to_pandas()\n",
    "\n",
    "print(f'Tracks: {len(tracks_df):,} | Dev sessions: {dev_df[\"session_id\"].nunique():,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Build BM25 Index"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "retriever = BM25Retriever(\n",
    "    track_df=tracks_df,\n",
    "    text_fields=['track_name', 'artist_name', 'tags']\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Run Retrieval on Dev Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tqdm import tqdm\n",
    "\n",
    "predictions = {}  # {session_id: [turn_recs, ...]}\n",
    "ground_truths = {}  # {session_id: [turn_gt, ...]}\n",
    "\n",
    "for session_id, group in tqdm(dev_df.groupby('session_id'), desc='Processing sessions'):\n",
    "    group = group.sort_values('turn_number')\n",
    "    session_preds = []\n",
    "    session_gts = []\n",
    "\n",
    "    context = ''\n",
    "    for _, row in group.iterrows():\n",
    "        context += f\" {row['utterance']}\"\n",
    "        results = retriever.retrieve(context.strip(), top_k=TOP_K)\n",
    "        session_preds.append([r['track_id'] for r in results])\n",
    "        # Assumes ground_truth column with relevant track_ids\n",
    "        session_gts.append(row.get('ground_truth_tracks', []))\n",
    "\n",
    "    predictions[session_id] = session_preds\n",
    "    ground_truths[session_id] = session_gts\n",
    "\n",
    "print(f'Processed {len(predictions)} sessions')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Evaluate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "\n",
    "ndcg_scores = compute_ndcg(predictions, ground_truths, k_values=[1, 10, 20])\n",
    "coverage = compute_catalog_coverage(predictions, catalog_size=len(tracks_df))\n",
    "\n",
    "results = {**ndcg_scores, 'Catalog_Coverage': coverage}\n",
    "pd.DataFrame([results]).T.rename(columns={0: 'Score'}).round(4)"
   ]
  }
 ],
